{
  "name": "edo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,magenta \"vite\" \"node server/index.mjs\"",
    "dev:vite": "vite",
    "dev:api": "node server/index.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:init-app": "docker exec -i edo-postgres psql -U edo -d edo < server/init/02-app-dictionary-and-appeals.sql",
    "db:init-event-log": "docker exec -i edo-postgres psql -U edo -d edo < server/init/03-app-event-log.sql",
    "db:netlify-init": "node scripts/netlify-db-init.mjs",
    "db:logs": "docker compose logs -f postgres",
    "build": "vite build",
    "preview": "vite preview",
    "tabular-to-md": "node scripts/tabular-to-markdown.mjs"
  },
  "dependencies": {
