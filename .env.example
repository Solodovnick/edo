# Скопируйте в `.env` для локальной разработки (`npm run dev`).
# Netlify: задайте те же имена в Site configuration → Environment variables
# (Vite подставляет VITE_* в момент `npm run build` — без них сборка идёт с пустыми строками).
# Значения: Supabase → Project Settings → API (URL и publishable/anon key).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
